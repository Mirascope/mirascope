{
  "name": "@mirascope/cloud",
  "version": "2.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "CLOUDFLARE_ENV=local vite dev",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' vite build",
    "build:staging": "CLOUDFLARE_ENV=staging bun run build",
    "build:production": "CLOUDFLARE_ENV=production bun run build",
    "postbuild": "pagefind --site dist/client --output-path dist/client/_pagefind --root-selector '[data-pagefind-body=\"true\"]' --",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "generate:api-docs": "bun run generate:api-docs:llm && bun run generate:api-docs:ops",
    "generate:api-docs:llm": "bun run api2mdx/generate-api-docs.ts --source-path ../python --package mirascope.llm --output ../content/docs/api --api-root /docs/api --product-slug llm --product-label LLM",
    "generate:api-docs:ops": "bun run api2mdx/generate-api-docs.ts --source-path ../python --package mirascope.ops --output ../content/docs/api --api-root /docs/api --internal-structure --product-slug ops --product-label Ops --append",
    "generate:social-cards-test": "bun run scripts/generate-test-social-cards.ts",
    "fetch-github-stats": "bun run scripts/fetch-github-stats.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "bun x tsc --build ./tsconfig.json",
    "format": "oxfmt --ignore-path .oxfmtignore .",
    "format:check": "oxfmt --ignore-path .oxfmtignore --check .",
    "lint": "bun run typecheck && bun run lint:oxlint && bun run format:check",
    "lint:oxlint": "oxlint .",
    "lint:oxlint:fix": "oxlint --fix .",
    "fix": "bun run format && bun run lint:oxlint:fix"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@resvg/resvg-js": "^2.6.2",
    "@shikijs/transformers": "^3.20.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.144.0",
    "@tanstack/react-start": "^1.145.3",
    "ai": "^6.0.42",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "embla-carousel-react": "^8.6.0",
    "frimousse": "^0.2.0",
    "glob": "^11.0.0",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.12.1",
    "motion": "^12.27.5",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "pagefind": "^1.4.0",
    "piscina": "^5.1.4",
    "react": "^19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.69.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "2.15.4",
    "rehype-pretty-code": "^0.14.1",
    "remark-gfm": "^4.0.1",
    "satori": "^0.19.1",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.1",
    "vaul": "^1.1.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.17.1",
    "@cloudflare/workers-types": "^4.20251231.0",
    "@effect/vitest": "^0.27.0",
    "@tanstack/react-router-devtools": "^1.144.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.0.16",
    "bun-types": "^1.3.5",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "web-vitals": "^4.2.4",
    "wrangler": "^4.54.0"
  }
}
